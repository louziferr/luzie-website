{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app-entwicklung/layout,_N_T_/app-entwicklung/page,_N_T_/app-entwicklung"
  },
  "segmentPaths": [
    "/_tree",
